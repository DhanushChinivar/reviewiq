{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SendReportEmail",
      "Effect": "Allow",
      "Action": "ses:SendEmail",
      "Resource": "arn:aws:ses:us-east-1:377228489522:identity/dhanushchinivar@gmail.com"
    },
    {
      "Sid": "ReadReports",
      "Effect": "Allow",
      "Action": "dynamodb:Query",
      "Resource": "arn:aws:dynamodb:us-east-1:377228489522:table/reviewiq-reports"
    },
    {
      "Sid": "ReadReportFiles",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::reviewiq-data/*"
    }
  ]
}
