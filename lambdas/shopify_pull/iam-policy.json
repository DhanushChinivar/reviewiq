{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadTokens",
      "Effect": "Allow",
      "Action": "dynamodb:Scan",
      "Resource": "arn:aws:dynamodb:us-east-1:377228489522:table/reviewiq-shopify-tokens"
    },
    {
      "Sid": "DecryptToken",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "arn:aws:kms:us-east-1:377228489522:key/fe81e30b-26a3-4469-a4b1-81ec83c6d680"
    },
    {
      "Sid": "WriteReviews",
      "Effect": "Allow",
      "Action": "dynamodb:PutItem",
      "Resource": "arn:aws:dynamodb:us-east-1:377228489522:table/reviewiq-reviews"
    },
    {
      "Sid": "WriteRawPayload",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::reviewiq-data/*"
    }
  ]
}
